# Shopify
SHOPIFY_STORE_DOMAIN=my-store.myshopify.com
SHOPIFY_CLIENT_ID=...        # from Dev Dashboard → App → Settings
SHOPIFY_CLIENT_SECRET=...    # from Dev Dashboard → App → Settings
SHOPIFY_API_VERSION=2024-04
# Note: access tokens are fetched at runtime via OAuth client_credentials grant
# and expire after 24h — do NOT hardcode a shpat_ token here

# WooCommerce
WOO_BASE_URL=https://my-wp-site.com
WOO_CONSUMER_KEY=ck_...
WOO_CONSUMER_SECRET=cs_...
